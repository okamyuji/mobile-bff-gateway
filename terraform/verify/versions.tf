terraform {
  required_version = ">= 1.8.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region  = var.aws_region
  profile = var.aws_profile

  default_tags {
    tags = {
      Project   = "mbg-verify"
      ManagedBy = "terraform"
      Purpose   = "mobile-bff-gateway-verification"
    }
  }
}
